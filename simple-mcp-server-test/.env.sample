# MCP Server Configuration
# Copy this file to .env and configure for your environment

# Transport mode: "stdio" for local development, "http" for infrastructure deployment
# Default: stdio
MCP_TRANSPORT=stdio

# HTTP mode settings (only used when MCP_TRANSPORT=http)
# Host to bind to - use 127.0.0.1 for localhost-only (recommended with nginx)
# Default: 127.0.0.1
MCP_HOST=127.0.0.1

# Port to listen on in HTTP mode
MCP_PORT=8063

# Example configurations:
#
# Local development (stdio):
#   MCP_TRANSPORT=stdio
#
# Infrastructure deployment (HTTP with nginx):
#   MCP_TRANSPORT=http
#   MCP_HOST=127.0.0.1
#   MCP_PORT=8000
#
# Infrastructure deployment (HTTP, all interfaces - NOT recommended):
#   MCP_TRANSPORT=http
#   MCP_HOST=0.0.0.0
#   MCP_PORT=8000
